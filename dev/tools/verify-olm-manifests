set -o errexit
set -o nounset
set -o pipefail

# keep in sync with dev/tools/sync-olm-manifests (copy-k8s-config in olm/Makefile)
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd -P)"
cd "${ROOT}"

TMP_DIR=$(mktemp -d)
exitHandler() (
  rm -rf "${TMP_DIR}"
)
trap exitHandler EXIT

echo "Checking OLM manifests are up to date..."
cp -a olm/config/. "${TMP_DIR}/"
make -C olm copy-k8s-config CONFIG_DIR="${TMP_DIR}"

if ! diff -rq "${TMP_DIR}" olm/config > /dev/null; then
  echo "OLM manifests not up to date. Did you run 'make fix-go-generate' or 'make fix-olm-manifests'?"
  while IFS= read -r line; do
    case "${line}" in
    "Files ${TMP_DIR}/"*)
      rel="${line#Files ${TMP_DIR}/}"
      rel="${rel%% and *}"
      echo "  olm/config/${rel}"
      ;;
    "Only in ${TMP_DIR}/"*)
      dir_and_file="${line#Only in ${TMP_DIR}/}"
      dir="${dir_and_file%%:*}"
      file="${dir_and_file#*: }"
      echo "  olm/config/${dir}/${file} (missing)"
      ;;
    "Only in olm/config/"*)
      dir_and_file="${line#Only in olm/config/}"
      dir="${dir_and_file%%:*}"
      file="${dir_and_file#*: }"
      echo "  olm/config/${dir}/${file} (extra)"
      ;;
    *)
      echo "  ${line}"
      ;;
    esac
  done < <(diff -rq "${TMP_DIR}" olm/config || true)
  exit 1
fi
