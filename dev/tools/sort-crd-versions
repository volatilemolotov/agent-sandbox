import os
import re
import sys

try:
    import yaml
except ImportError:
    print("Error: The 'PyYAML' package is required to sort and patch CRDs, but it is not installed.", file=sys.stderr)
    print("Please install it by running: pip install PyYAML", file=sys.stderr)
    sys.exit(1)

def parse_k8s_version(version_str):
    # Matches v<major>[{alpha,beta}<minor>]
    # Examples:
    # v1 -> (1, 3, 0)
    # v1beta1 -> (1, 2, 1)
    # v1alpha2 -> (1, 1, 2)
    match = re.match(r'^v(\d+)(?:(alpha|beta)(\d+))?$', version_str)
    if not match:
        return (0, 0, 0)
    
    major = int(match.group(1))
    track = match.group(2)
    minor = match.group(3)
    
    if track is None:
        track_priority = 3  # GA
        minor_val = 0
    elif track == 'beta':
        track_priority = 2
        minor_val = int(minor)
    elif track == 'alpha':
        track_priority = 1
        minor_val = int(minor)
    else:
        track_priority = 0
        minor_val = 0
        
    return (major, track_priority, minor_val)

def sort_crd_versions(file_path):
    with open(file_path, 'r') as f:
        try:
            docs = list(yaml.safe_load_all(f))
        except Exception as e:
            print(f"Error parsing {file_path}: {e}", file=sys.stderr)
            raise RuntimeError(f"failed to parse YAML in {file_path}: {e}") from e

    modified = False
    new_docs = []
    for doc in docs:
        if not doc:
            new_docs.append(doc)
            continue
        if doc.get('kind') == 'CustomResourceDefinition':
            spec = doc.get('spec', {})
            versions = spec.get('versions', [])
            if len(versions) > 1:
                # Force conversion strategy to Webhook and populate webhook configuration
                spec['conversion'] = {
                    'strategy': 'Webhook',
                    'webhook': {
                        'conversionReviewVersions': ['v1', 'v1beta1'],
                        'clientConfig': {
                            'service': {
                                'name': 'agent-sandbox-webhook-service',
                                'namespace': 'agent-sandbox-system',
                                'path': '/convert'
                            }
                        }
                    }
                }
                # Sort versions descending by Kubernetes version priority
                sorted_versions = sorted(versions, key=lambda v: parse_k8s_version(v.get('name', '')), reverse=True)
                if sorted_versions != versions:
                    spec['versions'] = sorted_versions
                modified = True
        new_docs.append(doc)

    if modified:
        with open(file_path, 'w') as f:
            # We must use sort_keys=False to preserve the field ordering from controller-gen!
            yaml.safe_dump_all(new_docs, f, sort_keys=False, default_flow_style=False)
        print(f"Sorted CRD versions in {file_path}")

def main():
    # Find the repo root from the script's location
    script_dir = os.path.dirname(os.path.realpath(__file__))
    repo_root = os.path.abspath(os.path.join(script_dir, '..', '..'))

    crd_dirs = [
        os.path.join(repo_root, 'k8s', 'crds'),
        os.path.join(repo_root, 'helm', 'crds'),
    ]

    for crd_dir in crd_dirs:
        if not os.path.isdir(crd_dir):
            continue
        for filename in os.listdir(crd_dir):
            if filename.endswith('.yaml') or filename.endswith('.yml'):
                file_path = os.path.join(crd_dir, filename)
                sort_crd_versions(file_path)

if __name__ == '__main__':
    main()
