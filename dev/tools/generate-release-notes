import os
import sys
import json
import subprocess
import argparse
import re


def get_previous_release_tag(current_tag):
    """Queries the latest stable release tag directly from GitHub using the gh CLI."""
    try:
        # Assumption: Currently only patching of the latest minor release happens. 
        # TODO: Support patching older minor releases
        latest_stable = subprocess.run(
            [
                "gh", "release", "list",
                "--json", "tagName,isLatest",
                "--jq", ".[] | select(.isLatest).tagName",
                "--repo", "kubernetes-sigs/agent-sandbox"
            ],
            check=True,
            text=True,
            stdout=subprocess.PIPE,
        ).stdout.strip()
        
        if latest_stable:
            print(f"INFO: Found latest stable release on GitHub: {latest_stable}")
            return latest_stable
            
        return None
    except subprocess.CalledProcessError as e:
        print(f"❌ Error: Failed to fetch latest release via gh CLI: {e}")
        sys.exit(1)


def get_commits(prev_tag, current_tag):
    range_str = f"{prev_tag}..{current_tag}" if prev_tag else current_tag
    try:
        raw_log = subprocess.run(
            ["git", "log", range_str, "--pretty=format:---COMMIT---%n%s%n%b"],
            check=True,
            text=True,
            stdout=subprocess.PIPE,
        ).stdout.strip()

        commits = []
        if raw_log:
            chunks = raw_log.split("---COMMIT---\n")
            for chunk in chunks:
                if not chunk.strip():
                    continue
                lines = chunk.splitlines()
                title = lines[0]
                body = "\n".join(lines[1:])
                commits.append({"title": title, "body": body})
        return commits
    except subprocess.CalledProcessError:
        return []


def get_pr_numbers(commits):
    """Extracts PR numbers from commits."""
    pr_numbers = []
    patterns = [r"\(#(\d+)\)$", r"Merge pull request #(\d+)"]

    for commit in commits:
        title = commit["title"]
        for pattern in patterns:
            match = re.search(pattern, title)
            if match:
                pr_numbers.append(int(match.group(1)))
                break
    return list(set(pr_numbers))


def fetch_prs_data(pr_numbers):
    """Fetches PR details (labels, body, author) once per PR to minimize API overhead."""
    prs_data = {}
    for pr in pr_numbers:
        try:
            out = subprocess.run(
                [
                    "gh",
                    "pr",
                    "view",
                    str(pr),
                    "--json",
                    "labels,body,author",
                    "--repo",
                    "kubernetes-sigs/agent-sandbox",
                ],
                check=True,
                text=True,
                stdout=subprocess.PIPE,
            ).stdout
            prs_data[pr] = json.loads(out)
        except subprocess.CalledProcessError:
            print(f"⚠️ Warning: Failed to fetch PR #{pr} details.")
    return prs_data


def get_contributors(prs_data):
    """Extracts verified GitHub handles of all PR authors."""
    contributors = set()
    for data in prs_data.values():
        author = data.get("author", {}).get("login")
        if author:
            contributors.add(f"@{author}")
    return sorted(list(contributors))


def get_breaking_changes(prs_data):
    """Extracts breaking changes from fetched PR data with action required label."""
    breaking_changes = []
    for pr, data in prs_data.items():
        labels = [l["name"] for l in data.get("labels", [])]
        if "release-note-action-required" in labels:
            body = data.get("body", "").strip()
            if body:
                breaking_changes.append(f"PR #{pr}: {body}")
    return breaking_changes


def get_pr_descriptions(prs_data):
    """Extracts PR descriptions from fetched PR data."""
    pr_descriptions = []
    for pr, data in prs_data.items():
        body = data.get("body", "").strip()
        if body:
            pr_descriptions.append(f"PR #{pr}: {body}")
    return pr_descriptions


def generate_release_notes(commits, breaking_changes, pr_descriptions, contributors, tag, installation_notes, model="gemini-2.5-flash"):
    """Generates curated release notes using Gemini via the Vertex AI API platform."""
    # Try importing the modern SDK
    try:
        from google import genai
        from google.genai import errors
    except ImportError:
        print("❌ Error: 'google-genai' library not installed. Run 'pip install google-genai'.")
        return None

    project_id = os.getenv("GCP_PROJECT", "").strip()
    location = os.getenv("GCP_LOCATION", "us-central1").strip()

    if not project_id:
        print("⚠️ GCP_PROJECT environment variable not set. Skipping Gemini release notes.")
        return None

    commit_titles = "\n".join([c["title"] for c in commits])
    commit_messages = "\n".join([f"- {c['title']}\n  {c['body']}" for c in commits])
    pr_desc_str = "\n".join([f"- {desc}" for desc in pr_descriptions])
    contributors_str = ", ".join(contributors)

    is_pre_release = bool(re.match(r"^v?\d+\.\d+\.\d+(?:\.)?rc\d+$", tag))
    pre_release_instruction = ""
    pre_release_example = ""
    if is_pre_release:
        pre_release_instruction = """
- Since this is a pre-release candidate, include a **⚠️ Pre-Release Notice** section immediately following the intro paragraph using GitHub alert syntax `> [!WARNING]`. Clearly state that this is a release candidate intended for testing/validation, not recommended for production, and include a call to action for testing relevant API/architectural changes."""
        pre_release_example = f"""
### ⚠️ Pre-Release Notice
> [!WARNING]
> This is a Release Candidate (RC) intended for early testing, validation, and feedback by maintainers and early adopters. It is not recommended for production environments.
> 
> <!-- Insert specific testing guidance or known pre-release limitations here, synthesized from commit history and PR descriptions -->
"""

    breaking_instruction = """
- Inspect the provided Breaking Changes list, Input Full Commit Messages, and Input PR Descriptions for any breaking changes, architectural deprecations, or required user actions (e.g., API group upgrades, field replacements, or modified defaults). If any are found, create a dedicated **⚠️ Breaking Changes / Action Required** section clearly explaining the impact and necessary user actions."""

    pr_number_instruction = """
- When referencing specific features, bug fixes, or breaking changes in bullet points, include the relevant PR numbers (e.g., `(#123)`) extracted directly from the input commit titles and PR descriptions. Do not invent PR numbers."""

    prompt = f"""**Task:** Generate curated, production-ready release notes for **Agent Sandbox release** {tag} from the provided information, following the structure and tone of the ideal example below.

**Instructions:**
- Generate the release notes with the following sections in order:
  1. Intro paragraph announcing the release.
  2. Pre-Release Notice (if applicable).
  3. Breaking Changes / Action Required (if applicable).
  4. Key Highlights (grouped under bold feature area subheadings like **Core Stability & Lifecycle Management**).
  5. Installation (insert the exact Installation block provided below).
  6. Contributors.
- Synthesize information from full commit messages and PR descriptions to describe changes accurately.
- List all contributors as @handle from the verified contributors list below.{pre_release_instruction}{breaking_instruction}{pr_number_instruction}

**Ideal Example Structure:**
```markdown
We're excited to announce the release of Agent Sandbox {tag}! This release introduces...
{pre_release_example}
### ⚠️ Breaking Changes / Action Required
* **API Group Upgrade (`v1beta1`) (#867):** The core and extension APIs have been upgraded...

### Key Highlights
#### Core Stability & Lifecycle Management
* **Orphan Adoption Restoration (#944):** Fixed a critical functional regression...

### Installation
[Insert exact Installation block here]

--------
### Contributors
We extend our sincere thanks to all contributors to this release:
@handle1, @handle2
```

Exact Installation Block to Insert:
{installation_notes.strip()}

Verified Contributors:
{contributors_str}

Input Commit Titles:
{commit_titles}

Input Full Commit Messages:
{commit_messages}

Input PR Descriptions:
{pr_desc_str}

Breaking Changes:
{breaking_changes}
"""

    try:
        # Initialize the GenAI Client pointing at Vertex AI
        client = genai.Client(
            vertexai=True,
            project=project_id,
            location=location
        )

        # Call Vertex AI Gemini Model
        response = client.models.generate_content(
            model=model,
            contents=prompt,
        )
        
        return response.text

    except errors.APIError as e:
        print(f"⚠️ Vertex AI API Error calling Gemini ({e.code}: {e.message}). Skipping release notes.")
        return None
    except Exception as e:
        print(f"⚠️ Unexpected Error calling Vertex AI ({type(e).__name__}: {e}). Skipping release notes.")
        return None


def main():
    parser = argparse.ArgumentParser(description="Generate and preview release notes.")
    parser.add_argument(
        "--tag", required=True, help="The target git tag for the release."
    )
    parser.add_argument(
        "--output", default="release_notes_preview.md", help="File to save notes to."
    )
    parser.add_argument(
        "--model", default=os.getenv("GEMINI_MODEL", "gemini-2.5-flash"), help="The Gemini model to use."
    )
    args = parser.parse_args()

    tag = args.tag

    prev_tag = get_previous_release_tag(tag)
    print(f"INFO: Found previous tag: {prev_tag}")
    commits = get_commits(prev_tag, tag)

    # Extract PR numbers and fetch details once per PR to minimize API overhead
    pr_numbers = get_pr_numbers(commits)
    prs_data = fetch_prs_data(pr_numbers)
    contributors = get_contributors(prs_data)
    breaking_changes = get_breaking_changes(prs_data)
    pr_descriptions = get_pr_descriptions(prs_data)

    installation_notes = f"""
### Installation

#### Standard Install (Core + Extensions)
Recommended for most users and GitOps engines (Argo CD, Config Sync, kustomize):
```bash
kubectl apply -f https://github.com/kubernetes-sigs/agent-sandbox/releases/download/{tag}/sandbox-with-extensions.yaml
```

#### Selective Install
Install components separately:
```bash
# Core only:
kubectl apply -f https://github.com/kubernetes-sigs/agent-sandbox/releases/download/{tag}/sandbox.yaml

# Extensions (opt-in):
kubectl apply -f https://github.com/kubernetes-sigs/agent-sandbox/releases/download/{tag}/extensions.yaml
```

#### Python SDK
```bash
pip install k8s-agent-sandbox=={tag.lstrip('v')}
```
"""

    # Generate release notes using breaking changes, PR descriptions, and verified contributors
    if not commits:
        print("INFO: No commits found between tags. Skipping release notes generation.")
        gemini_notes = None
    else:
        gemini_notes = generate_release_notes(
            commits, "\n".join(breaking_changes), pr_descriptions, contributors, tag, installation_notes, model=args.model
        )
        if not gemini_notes:
            print("⚠️ Warning: Failed to generate release notes using Gemini. Proceeding best-effort.", file=sys.stderr)

    combined_content = f"# 🚀 Announcing Agent Sandbox {tag}!\n\n"
    if gemini_notes:
        combined_content += gemini_notes + "\n"
        if not re.search(r"^#+\s+Installation", gemini_notes, re.MULTILINE | re.IGNORECASE):
            combined_content += "\n" + installation_notes + "\n"
    else:
        combined_content += installation_notes + "\n"

    if combined_content:
        print(f"INFO: Saving release notes to {args.output}...")
        with open(args.output, "w") as f:
            f.write(combined_content)
        print("\n--- Preview ---\n")
        print(combined_content)
    else:
        print("❌ No notes could be generated.")


if __name__ == "__main__":
    main()
