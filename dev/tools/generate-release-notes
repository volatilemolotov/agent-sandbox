import os
import sys
import json
import subprocess
import argparse
import re


def get_previous_release_tag(current_tag):
    """Queries the latest stable release tag directly from GitHub using the gh CLI."""
    try:
        # Assumption: Currently only patching of the latest minor release happens. 
        # TODO: Support patching older minor releases
        latest_stable = subprocess.run(
            [
                "gh", "release", "list",
                "--json", "tagName,isLatest",
                "--jq", ".[] | select(.isLatest).tagName",
                "--repo", "kubernetes-sigs/agent-sandbox"
            ],
            check=True,
            text=True,
            stdout=subprocess.PIPE,
        ).stdout.strip()
        
        if latest_stable:
            print(f"INFO: Found latest stable release on GitHub: {latest_stable}")
            return latest_stable
            
        return None
    except subprocess.CalledProcessError as e:
        print(f"❌ Error: Failed to fetch latest release via gh CLI: {e}")
        sys.exit(1)


def get_commits(prev_tag, current_tag):
    range_str = f"{prev_tag}..{current_tag}" if prev_tag else current_tag
    try:
        raw_log = subprocess.run(
            ["git", "log", range_str, "--pretty=format:---COMMIT---%n%s%n%b"],
            check=True,
            text=True,
            stdout=subprocess.PIPE,
        ).stdout.strip()

        commits = []
        if raw_log:
            chunks = raw_log.split("---COMMIT---\n")
            for chunk in chunks:
                if not chunk.strip():
                    continue
                lines = chunk.splitlines()
                title = lines[0]
                body = "\n".join(lines[1:])
                commits.append({"title": title, "body": body})
        return commits
    except subprocess.CalledProcessError:
        return []


def get_pr_numbers(commits):
    """Extracts PR numbers from commits."""
    pr_numbers = []
    patterns = [r"\(#(\d+)\)$", r"Merge pull request #(\d+)"]

    for commit in commits:
        title = commit["title"]
        for pattern in patterns:
            match = re.search(pattern, title)
            if match:
                pr_numbers.append(int(match.group(1)))
                break
    return list(set(pr_numbers))


def fetch_prs_data(pr_numbers):
    """Fetches PR details (labels, body, author) once per PR to minimize API overhead."""
    prs_data = {}
    for pr in pr_numbers:
        try:
            out = subprocess.run(
                [
                    "gh",
                    "pr",
                    "view",
                    str(pr),
                    "--json",
                    "labels,body,author",
                    "--repo",
                    "kubernetes-sigs/agent-sandbox",
                ],
                check=True,
                text=True,
                stdout=subprocess.PIPE,
            ).stdout
            prs_data[pr] = json.loads(out)
        except subprocess.CalledProcessError:
            print(f"⚠️ Warning: Failed to fetch PR #{pr} details.")
    return prs_data


def get_contributors(prs_data):
    """Extracts verified GitHub handles of all PR authors."""
    contributors = set()
    for data in prs_data.values():
        author = data.get("author", {}).get("login")
        if author:
            contributors.add(f"@{author}")
    return sorted(list(contributors))


def get_breaking_changes(prs_data):
    """Extracts breaking changes from fetched PR data with action required label."""
    breaking_changes = []
    for pr, data in prs_data.items():
        labels = [l["name"] for l in data.get("labels", [])]
        if "release-note-action-required" in labels:
            body = data.get("body", "").strip()
            if body:
                breaking_changes.append(f"PR #{pr}: {body}")
    return breaking_changes


def get_pr_descriptions(prs_data):
    """Extracts PR descriptions from fetched PR data."""
    pr_descriptions = []
    for pr, data in prs_data.items():
        body = data.get("body", "").strip()
        if body:
            pr_descriptions.append(f"PR #{pr}: {body}")
    return pr_descriptions


def get_new_authors(prev_tag, current_tag):
    """Returns the list of Name <email> for verified first-time contributors in this release."""
    if not prev_tag:
        return []
    try:
        past_emails = set(
            subprocess.run(
                ["git", "log", prev_tag, "--pretty=format:%ae"],
                check=True, text=True, stdout=subprocess.PIPE
            ).stdout.splitlines()
        )
        
        current_commits = subprocess.run(
            ["git", "log", f"{prev_tag}..{current_tag}", "--pretty=format:%an <%ae>"],
            check=True, text=True, stdout=subprocess.PIPE
        ).stdout.splitlines()
        
        new_authors = set()
        for commit in current_commits:
            commit = commit.strip()
            if not commit:
                continue
            match = re.search(r'<([^>]+)>$', commit)
            if match:
                email = match.group(1)
                if email not in past_emails:
                    new_authors.add(commit)
        return sorted(list(new_authors))
    except subprocess.CalledProcessError:
        return []


def generate_highlights(commits, breaking_changes, pr_descriptions, contributors, new_authors, tag, model="gemini-2.5-flash"):
    """Generates release highlights using Gemini via the Vertex AI API platform."""
    # Try importing the modern SDK
    try:
        from google import genai
        from google.genai import errors
    except ImportError:
        print("❌ Error: 'google-genai' library not installed. Run 'pip install google-genai'.")
        return None

    project_id = os.getenv("GCP_PROJECT", "").strip()
    location = os.getenv("GCP_LOCATION", "us-central1").strip()

    if not project_id:
        print("⚠️ GCP_PROJECT environment variable not set. Skipping Gemini highlights.")
        return None

    commit_titles = "\n".join([c["title"] for c in commits])
    commit_messages = "\n".join([f"- {c['title']}\n  {c['body']}" for c in commits])
    pr_desc_str = "\n".join([f"- {desc}" for desc in pr_descriptions])
    contributors_str = ", ".join(contributors)
    new_authors_str = "\n".join([f"- {a}" for a in new_authors])

    prompt = f"""**Task:** Generate curated release notes for **Agent Sandbox release draft** {tag} from the provided information, following the structure and tone of the ideal example below.

**Instructions:**
- Generate only the **Key Highlights**, **Contributors**, and **New Contributors** sections.
- Summarize the highlights into a few key areas with bold titles describing the feature area (e.g., **Python SDK Advancements**, **Core Stability**).
- Synthesize information from full commit messages and PR descriptions to describe changes accurately.
- List all contributors as @handle from the verified contributors list below.
- The verified contributors list and the verified first-time authors list use different identifier formats. Do not try to match or convert between them.
- For the "New Contributors" section, list **only** the @handle from the verified new authors list below, exactly as provided. If the verified new authors list is empty, omit the "New Contributors" section entirely.

Verified Contributors:
{contributors_str}

Verified New Authors (First-Time Contributors):
{new_authors_str}

Input Commit Titles:
{commit_titles}

Input Full Commit Messages:
{commit_messages}

Input PR Descriptions:
{pr_desc_str}

Breaking Changes:
{breaking_changes}
"""

    try:
        # Initialize the GenAI Client pointing at Vertex AI
        client = genai.Client(
            vertexai=True,
            project=project_id,
            location=location
        )

        # Call Vertex AI Gemini Model
        response = client.models.generate_content(
            model=model,
            contents=prompt,
        )
        
        return response.text

    except errors.APIError as e:
        print(f"⚠️ Vertex AI API Error calling Gemini ({e.code}: {e.message}). Skipping highlights.")
        return None
    except Exception as e:
        print(f"⚠️ Unexpected Error calling Vertex AI ({type(e).__name__}: {e}). Skipping highlights.")
        return None


def main():
    parser = argparse.ArgumentParser(description="Generate and preview release notes.")
    parser.add_argument(
        "--tag", required=True, help="The target git tag for the release."
    )
    parser.add_argument(
        "--output", default="release_notes_preview.md", help="File to save notes to."
    )
    parser.add_argument(
        "--model", default=os.getenv("GEMINI_MODEL", "gemini-2.5-flash"), help="The Gemini model to use."
    )
    args = parser.parse_args()

    tag = args.tag

    prev_tag = get_previous_release_tag(tag)
    print(f"INFO: Found previous tag: {prev_tag}")
    commits = get_commits(prev_tag, tag)

    # Extract PR numbers and fetch details once per PR to minimize API overhead
    pr_numbers = get_pr_numbers(commits)
    prs_data = fetch_prs_data(pr_numbers)
    contributors = get_contributors(prs_data)
    new_authors = get_new_authors(prev_tag, tag)
    breaking_changes = get_breaking_changes(prs_data)
    pr_descriptions = get_pr_descriptions(prs_data)

    # Generate highlights using breaking changes, PR descriptions, verified contributors, and verified new authors
    if not commits:
        print("INFO: No commits found between tags. Skipping highlights generation.")
        highlights = None
    else:
        highlights = generate_highlights(
            commits, "\n".join(breaking_changes), pr_descriptions, contributors, new_authors, tag, model=args.model
        )
        if not highlights:
            print("⚠️ Warning: Failed to generate release highlights using Gemini. Proceeding best-effort.", file=sys.stderr)

    installation_notes = f"""
### Installation

#### Core & Extensions
```bash
# To install only the core components:
kubectl apply -f https://github.com/kubernetes-sigs/agent-sandbox/releases/download/{tag}/manifest.yaml

# To install the extensions components:
kubectl apply -f https://github.com/kubernetes-sigs/agent-sandbox/releases/download/{tag}/extensions.yaml
```

#### Python SDK
```bash
pip install k8s-agent-sandbox=={tag.lstrip('v')}
```
"""

    combined_content = f"# 🚀 Announcing Agent Sandbox {tag}!\n"
    if highlights:
        combined_content += highlights + "\n\n"
        combined_content += installation_notes + "\n\n"
    else:
        combined_content += installation_notes + "\n\n"

    if combined_content:
        print(f"INFO: Saving release notes to {args.output}...")
        with open(args.output, "w") as f:
            f.write(combined_content)
        print("\n--- Preview ---\n")
        print(combined_content)
    else:
        print("❌ No notes could be generated.")


if __name__ == "__main__":
    main()
