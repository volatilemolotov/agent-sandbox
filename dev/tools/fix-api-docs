import os
import subprocess
import sys

def run_command(cmd, cwd):
    """Run a shell command and exit if it fails."""
    print(f"Running: {' '.join(cmd)}")
    try:
        # Use check=True to raise an exception on non-zero exit codes
        subprocess.run(cmd, cwd=cwd, check=True)
    except subprocess.CalledProcessError as e:
        print(f"::error::Command failed with exit code {e.returncode}: {' '.join(cmd)}", file=sys.stderr)
        sys.exit(e.returncode)

def main():
    # Resolve the repository root directory relative to this script
    _repo_root = os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

    # The Make targets required to generate all documentation
    make_targets = [
        "generate-api-docs",
        "generate-go-docs",
        "generate-python-docs"
    ]

    print("Regenerating API and SDK documentation...")

    for target in make_targets:
        # Run `make <target>` from the root of the repository
        run_command(["make", target], cwd=_repo_root)

    print("All documentation generated successfully!")

if __name__ == "__main__":
    main()
