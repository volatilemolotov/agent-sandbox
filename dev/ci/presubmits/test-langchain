"""
Unit tests for the langchain (coding_agent) example.

coding_agent.py runs inside the sandbox container as a LangGraph-driven
coding agent. These tests cover the pure logic (CodeGenerationLLM._clean_code,
CodingAgent.should_continue) and the agent's graph node functions and
LocalCodeExecutor, with the LLM, executor, and subprocess boundaries
mocked. The real torch/transformers packages are never installed or
exercised. No kind cluster or container build is needed.
"""

import os
import subprocess
import sys

_repo_root = os.path.dirname(os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__)))))
EXAMPLE_DIR = os.path.join(_repo_root, "examples", "langchain")


def main():
    def run(cmd, **kwargs):
        print(f"+ {' '.join(cmd)}")
        return subprocess.run(cmd, **kwargs)

    print("\n-- Installing langchain unit test dependencies --")
    run(["pip", "install", "--break-system-packages", "pytest"], check=True)

    print("\n-- Running langchain unit tests --")
    result = run(["python3", "-m", "pytest", "test_coding_agent.py", "-v"], cwd=EXAMPLE_DIR)
    return result.returncode


if __name__ == "__main__":
    sys.exit(main())
