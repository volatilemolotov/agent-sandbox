"""
Unit tests for the mcp-server-sandbox example.

mcp_server.py runs inside the sandbox container; these tests call its
blob-store tool functions (list_blobs, write_random_blob, read_blob)
directly against a scratch workspace directory. No MCP stdio transport,
kind cluster, or container build is needed.
"""

import os
import subprocess
import sys

_repo_root = os.path.dirname(os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__)))))
EXAMPLE_DIR = os.path.join(_repo_root, "examples", "mcp-server-sandbox")


def main():
    def run(cmd, **kwargs):
        print(f"+ {' '.join(cmd)}")
        return subprocess.run(cmd, **kwargs)

    print("\n-- Installing mcp-server-sandbox unit test dependencies --")
    run(["pip", "install", "--break-system-packages", "mcp", "pytest"], check=True)

    print("\n-- Running mcp-server-sandbox unit tests --")
    result = run(["python3", "-m", "pytest", "test_mcp_server.py", "-v"], cwd=EXAMPLE_DIR)
    return result.returncode


if __name__ == "__main__":
    sys.exit(main())
