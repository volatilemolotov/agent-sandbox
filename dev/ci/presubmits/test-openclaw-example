"""
End-to-end test for the openclaw-sandbox example.

Deploys the openclaw-sandbox example directly to the Prow GKE cluster
in a dedicated namespace, verifies the OpenClaw gateway is reachable,
then cleans up.

Requirements (one-time cluster setup):
  - agent-sandbox CRDs and controller installed (namespace: agent-sandbox-system)
  - namespace 'openclaw-test' exists with RBAC for test-pods/default service account
"""

import os
import subprocess
import sys
import time

_repo_root = os.path.dirname(os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__)))))

EXAMPLE_DIR = os.path.join(_repo_root, "examples", "openclaw-sandbox")
NAMESPACE = "openclaw-test"
GATEWAY_PORT = 18789
POD_READY_TIMEOUT = "300s"


def run(cmd, check=True, **kwargs):
    print(f"+ {' '.join(cmd)}")
    return subprocess.run(cmd, check=check, **kwargs)


def kubectl(*args, check=True, **kwargs):
    return run(["kubectl", "-n", NAMESPACE, *args], check=check, **kwargs)


def cleanup():
    print("\n-- Cleaning up --")
    kubectl("delete", "sandbox", "openclaw-sandbox", "--ignore-not-found", check=False)
    kubectl("delete", "configmap", "openclaw-config", "--ignore-not-found", check=False)
    kubectl("delete", "pvc", "--all", check=False)


def main():
    print("=== openclaw-sandbox e2e test ===")
    print(f"Namespace: {NAMESPACE}")

    # Clean up any leftover resources from a previous run
    cleanup()

    try:
        # Apply ConfigMap
        print("\n-- Applying openclaw-config.yaml --")
        kubectl("apply", "-f", os.path.join(EXAMPLE_DIR, "openclaw-config.yaml"))

        # Apply Sandbox
        print("\n-- Applying openclaw-sandbox.yaml --")
        kubectl("apply", "-f", os.path.join(EXAMPLE_DIR, "openclaw-sandbox.yaml"))

        # Wait for pod to be Ready
        print(f"\n-- Waiting for pod to be Ready (timeout {POD_READY_TIMEOUT}) --")
        kubectl(
            "wait", "--for=condition=ready", "pod",
            "--selector=sandbox=openclaw-sandbox",
            f"--timeout={POD_READY_TIMEOUT}",
        )

        # Curl the service ClusterIP directly (same cluster, no port-forward needed)
        svc_url = f"http://openclaw-sandbox.{NAMESPACE}.svc.cluster.local:{GATEWAY_PORT}"
        print(f"\n-- Testing gateway at {svc_url} --")
        # Retry for up to 30s in case the service endpoint isn't ready yet
        result = None
        for attempt in range(6):
            result = subprocess.run(
                ["curl", "-sf", "--max-time", "10",
                 "-o", "/dev/null", "-w", "%{http_code}",
                 svc_url],
                capture_output=True, text=True,
            )
            http_code = result.stdout.strip()
            if http_code.isdigit() and int(http_code) > 0:
                break
            print(f"  attempt {attempt+1}: got '{http_code}', retrying...")
            time.sleep(5)

        http_code = result.stdout.strip()
        print(f"Gateway HTTP response code: {http_code}")
        # Any HTTP response (incl. 401/404) means the server is up
        if not http_code.isdigit() or int(http_code) == 0:
            print("ERROR: gateway did not respond.", file=sys.stderr)
            sys.exit(1)
        print("SUCCESS: OpenClaw gateway is reachable.")

    except subprocess.CalledProcessError as e:
        print(f"\nERROR: command failed: {e}", file=sys.stderr)
        # Print pod logs to help diagnose failures
        kubectl("logs", "-l", "sandbox=openclaw-sandbox",
                "--tail=50", check=False)
        kubectl("describe", "pod", "-l", "sandbox=openclaw-sandbox",
                check=False)
        cleanup()
        sys.exit(1)

    cleanup()
    print("\n=== Test passed ===")


if __name__ == "__main__":
    main()
