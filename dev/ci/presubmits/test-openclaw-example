"""
Validates the openclaw-sandbox example manifests and verifies the container
image is reachable, without requiring a running cluster or Docker daemon.

Checks:
  1. YAML is valid and parseable
  2. Required Sandbox fields are present (apiVersion, kind, spec.podTemplate)
  3. Container image reference is reachable (via skopeo inspect)
  4. ConfigMap has the expected openclaw.json key
"""

import os
import subprocess
import sys

_repo_root = os.path.dirname(os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__)))))
if _repo_root not in sys.path:
    sys.path.insert(0, _repo_root)

EXAMPLE_DIR = os.path.join(_repo_root, "examples", "openclaw-sandbox")
SANDBOX_MANIFEST = os.path.join(EXAMPLE_DIR, "openclaw-sandbox.yaml")
CONFIG_MANIFEST = os.path.join(EXAMPLE_DIR, "openclaw-config.yaml")


def fail(msg):
    print(f"FAIL: {msg}", file=sys.stderr)
    sys.exit(1)


def check(condition, msg):
    if not condition:
        fail(msg)
    print(f"OK: {msg}")


def load_yaml(path):
    try:
        import yaml
    except ImportError:
        subprocess.check_call([sys.executable, "-m", "pip", "install", "pyyaml", "-q"])
        import yaml
    with open(path) as f:
        return list(yaml.safe_load_all(f))


def main():
    print("=== Validating openclaw-sandbox example ===")

    # 1. YAML parses without errors
    print("\n-- Checking YAML syntax --")
    try:
        sandbox_docs = load_yaml(SANDBOX_MANIFEST)
        config_docs = load_yaml(CONFIG_MANIFEST)
    except Exception as e:
        fail(f"YAML parse error: {e}")

    check(len(sandbox_docs) == 1, "openclaw-sandbox.yaml has exactly one document")
    check(len(config_docs) == 1, "openclaw-config.yaml has exactly one document")

    sandbox = sandbox_docs[0]
    configmap = config_docs[0]

    # 2. Sandbox manifest structure
    print("\n-- Checking Sandbox manifest fields --")
    check(sandbox.get("apiVersion") == "agents.x-k8s.io/v1beta1",
          "apiVersion is agents.x-k8s.io/v1beta1")
    check(sandbox.get("kind") == "Sandbox",
          "kind is Sandbox")
    check(sandbox.get("metadata", {}).get("name"),
          "metadata.name is set")

    spec = sandbox.get("spec", {})
    check("podTemplate" in spec,
          "spec.podTemplate is present")
    containers = spec.get("podTemplate", {}).get("spec", {}).get("containers", [])
    check(len(containers) > 0,
          "spec.podTemplate.spec.containers is non-empty")

    container = containers[0]
    image = container.get("image", "")
    check(bool(image), f"container image is set: {image}")
    check("volumeMounts" in container,
          "container has volumeMounts")
    check(len(spec.get("volumeClaimTemplates", [])) > 0,
          "spec.volumeClaimTemplates is present (persistent storage)")

    # 3. ConfigMap structure
    print("\n-- Checking ConfigMap --")
    check(configmap.get("kind") == "ConfigMap",
          "kind is ConfigMap")
    check("openclaw.json" in configmap.get("data", {}),
          "ConfigMap contains openclaw.json key")

    # 4. Verify container image is reachable
    print(f"\n-- Checking container image reachability: {image} --")
    # Try crane, then skopeo, then curl against the ghcr.io registry API
    result = None
    for cmd in (
        ["crane", "digest", image],
        ["skopeo", "inspect", f"docker://{image}"],
    ):
        try:
            result = subprocess.run(cmd, capture_output=True, text=True)
            if result.returncode == 0:
                break
        except FileNotFoundError:
            continue

    if result is None or result.returncode != 0:
        # curl fallback: anonymous token request then manifest HEAD
        registry, tag = image.rsplit(":", 1)
        _, repo = registry.split("/", 1)
        token_result = subprocess.run(
            ["curl", "-sf", f"https://ghcr.io/token?scope=repository:{repo}:pull"],
            capture_output=True, text=True,
        )
        import json
        token = json.loads(token_result.stdout).get("token", "")
        result = subprocess.run(
            ["curl", "-sf", "--head",
             "-H", f"Authorization: Bearer {token}",
             "-H", "Accept: application/vnd.oci.image.manifest.v1+json",
             f"https://ghcr.io/v2/{repo}/manifests/{tag}"],
            capture_output=True, text=True,
        )
    check(result.returncode == 0,
          f"Container image {image} is reachable from registry")

    print("\n=== All checks passed ===")


if __name__ == "__main__":
    main()
