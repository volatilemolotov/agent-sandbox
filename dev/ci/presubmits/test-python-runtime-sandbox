"""
End-to-end test for the python-runtime-sandbox example.

Creates a kind cluster, deploys the agent-sandbox controller, builds the
sandbox-runtime image, applies the sandbox manifest, and verifies the
runtime server passes all tester.go checks.
"""

import os
import subprocess
import sys
import time

_repo_root = os.path.dirname(os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__)))))
if _repo_root not in sys.path:
    sys.path.insert(0, _repo_root)

from dev.ci.shared.runner import TestRunner

EXAMPLE_DIR = os.path.join(_repo_root, "examples", "python-runtime-sandbox")
SERVER_PORT = 8888
POD_READY_TIMEOUT = "300s"
IMAGE_NAME = "sandbox-runtime:latest"
SANDBOX_NAME = "sandbox-python-example"
POD_SELECTOR = "sandbox=my-python-sandbox"


class PythonRuntimeTestRunner(TestRunner):
    def __init__(self):
        super().__init__("python-runtime-test", "e2e test for the python-runtime-sandbox example")

    def run_tests(self, args):
        env = os.environ.copy()
        env["KUBECONFIG"] = os.path.join(self.repo_root, "bin", "KUBECONFIG")

        def run(cmd, check=True, **kwargs):
            print(f"+ {' '.join(cmd)}")
            return subprocess.run(cmd, check=check, **kwargs)

        def kubectl(*kubectl_args, check=True, **kwargs):
            return run(["kubectl", *kubectl_args], env=env, check=check, **kwargs)

        def cleanup():
            print("\n-- Cleaning up --")
            kubectl("delete", "-f", os.path.join(EXAMPLE_DIR, "sandbox-python-kind.yaml"),
                    "--ignore-not-found", check=False)

        print("=== python-runtime-sandbox e2e test ===")
        cleanup()

        try:
            print("\n-- Building sandbox-runtime image --")
            run(["docker", "build", "-t", IMAGE_NAME, EXAMPLE_DIR])

            print("\n-- Loading image into kind cluster --")
            run(["kind", "load", "docker-image", IMAGE_NAME, "--name", self.name])

            print("\n-- Applying sandbox-python-kind.yaml --")
            kubectl("apply", "-f", os.path.join(EXAMPLE_DIR, "sandbox-python-kind.yaml"))

            print(f"\n-- Waiting for pod to be Ready (timeout {POD_READY_TIMEOUT}) --")
            kubectl("wait", "--for=condition=ready", "pod",
                    f"--selector={POD_SELECTOR}",
                    f"--timeout={POD_READY_TIMEOUT}")

            print(f"\n-- Port-forwarding server on 127.0.0.1:{SERVER_PORT} --")
            pf = subprocess.Popen(
                ["kubectl", "port-forward", f"pod/{SANDBOX_NAME}", f"{SERVER_PORT}:{SERVER_PORT}"],
                env=env,
            )
            try:
                time.sleep(5)
                print("\n-- Running tester.go --")
                result = run(
                    ["go", "run", os.path.join(EXAMPLE_DIR, "tester.go"),
                     "127.0.0.1", str(SERVER_PORT)],
                    check=False,
                )
            finally:
                pf.terminate()
                pf.wait()

            if result.returncode != 0:
                print("ERROR: tester.go reported failures.", file=sys.stderr)
                kubectl("logs", f"pod/{SANDBOX_NAME}", "--tail=50", check=False)
                cleanup()
                return subprocess.CompletedProcess([], 1)

        except subprocess.CalledProcessError as e:
            print(f"\nERROR: command failed: {e}", file=sys.stderr)
            kubectl("logs", f"pod/{SANDBOX_NAME}", "--tail=50", check=False)
            kubectl("describe", "pod", f"-l{POD_SELECTOR}", check=False)
            cleanup()
            return subprocess.CompletedProcess([], 1)

        cleanup()
        print("\n=== Test passed ===")
        return subprocess.CompletedProcess([], 0)


if __name__ == "__main__":
    runner = PythonRuntimeTestRunner()
    runner.main()
