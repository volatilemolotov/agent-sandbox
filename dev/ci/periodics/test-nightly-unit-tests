"""Reruns the unit-test-only presubmit suites nightly against main.

Unlike the presubmits, this isn't gated by run_if_changed, so it also catches
regressions unrelated to a code diff (e.g. an unpinned pip dependency bump or
a base image update). Failing components get a GitHub issue filed/updated via
dev/ci/shared/github_issue.py, in addition to the normal Prow/TestGrid red,
since TestGrid isn't watched by everyone.
"""

import os
import subprocess
import sys

_repo_root = os.path.dirname(os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__)))))
if _repo_root not in sys.path:
    sys.path.insert(0, _repo_root)

from dev.ci.shared import github_issue

REPO = "kubernetes-sigs/agent-sandbox"

# Unit-test-only presubmits: no kind cluster or container build required, so
# they're cheap enough to rerun nightly in a single pod.
COMPONENTS = [
    "test-unit",
    "test-langchain",
    "test-analytics-tool",
    "test-mcp-server-sandbox",
]


def main():
    failures = []
    for component in COMPONENTS:
        script = os.path.join(_repo_root, "dev", "ci", "presubmits", component)
        print(f"\n-- Running {component} --")
        result = subprocess.run([script], cwd=_repo_root, capture_output=True, text=True)
        print(result.stdout)
        print(result.stderr)

        if result.returncode != 0:
            failures.append(component)
            log_excerpt = (result.stdout + result.stderr)[-4000:]
            try:
                github_issue.ensure_failure_issue(REPO, component, log_excerpt)
            except Exception as e:
                print(f"WARNING: failed to file/update GitHub issue for {component}: {e}")

    if failures:
        print(f"\nFailed components: {', '.join(failures)}")
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
