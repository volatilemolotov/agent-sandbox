"""Strip a YAML key and its children from a file.

Used to remove keys that operator-sdk auto-generates or that conflict
with the controller's runtime management.  Examples:

  hack/strip-csv-webhookdefs csv.yaml webhookdefinitions
      Removes spec.webhookdefinitions from a CSV.

  hack/strip-csv-webhookdefs crd.yaml clientConfig
      Removes spec.conversion.webhook.clientConfig from a CRD,
      keeping strategy: Webhook and conversionReviewVersions.
"""

import sys


def main():
    if len(sys.argv) < 3:
        print(f"usage: {sys.argv[0]} <yaml-path> <key>", file=sys.stderr)
        sys.exit(1)

    path = sys.argv[1]
    key = sys.argv[2]
    suffix = key + ":"

    with open(path) as f:
        lines = f.readlines()

    result = []
    skip = False
    indent = 0
    seen_deeper = False
    for line in lines:
        stripped = line.rstrip()
        if not skip and stripped.lstrip() == suffix:
            indent = len(stripped) - len(stripped.lstrip())
            skip = True
            seen_deeper = False
            continue
        if skip:
            if not stripped:
                continue
            line_indent = len(stripped) - len(stripped.lstrip())
            if line_indent > indent:
                seen_deeper = True
                continue
            if line_indent < indent:
                skip = False
            else:
                content = stripped[line_indent:]
                if content and content[0].isalpha():
                    skip = False
                elif content and content[0] == "-":
                    seen_deeper = False
                    continue
                else:
                    skip = False
        result.append(line)

    with open(path, "w") as f:
        f.writelines(result)


if __name__ == "__main__":
    main()
